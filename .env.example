# POVChat Environment Variables
# Copy this to .env and fill in your API keys

# AI Provider Keys (Server-side only)
DEEPSEEK_KEY=sk-your-deepseek-key
GROK_KEY=xai-your-grok-key

# Frontend-accessible keys (prefixed with VITE_)
VITE_GEMINI_API_KEY=your-gemini-key
VITE_OPENAI_API_KEY=your-openai-key

# Server
PORT=3001
